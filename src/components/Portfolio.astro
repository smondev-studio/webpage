---
import { getStores } from '../lib/projects';

const stores = await getStores();
---

<section id="clientes" class="py-16 sm:py-20 lg:py-24 transition-colors duration-300 relative overflow-hidden" style="background-color: var(--bg-secondary);">
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-cyan-500/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-10 w-80 h-80 bg-fuchsia-500/5 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black mb-4" style="color: var(--text-primary);">
        Tiendas de nuestros clientes
      </h2>
      <p class="text-base sm:text-lg max-w-xl mx-auto" style="color: var(--text-muted);">
        Proyectos desarrollados sobre la misma plataforma, cada uno con su identidad propia.
      </p>
    </div>

    {stores.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        {stores.map((store) => (
          <a href={store.url} target="_blank" rel="noopener noreferrer"
            class="rounded-3xl overflow-hidden border transition-all duration-300 hover:border-orange-500/40 group block backdrop-blur-sm relative"
            style="background: linear-gradient(135deg, var(--bg-card) 0%, rgba(139,92,246,0.04) 100%); border-color: var(--border);">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
              style="background: radial-gradient(circle at 50% 0%, rgba(249,115,22,0.08) 0%, transparent 60%);">
            </div>
            <div class="relative z-10">
            <div class="relative h-48 overflow-hidden"
              style="background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);">
              <img src={store.image} alt={store.name} loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
            </div>
            <div class="p-6">
              <div class="inline-flex items-center gap-2 bg-emerald-500/15 border border-emerald-500/30 text-emerald-400 text-xs font-semibold px-3 py-1 rounded-full mb-3">
                <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></span>
                En producción
              </div>
              <h3 class="text-xl font-black mb-2 group-hover:text-orange-500 transition-colors"
                style="color: var(--text-primary);">{store.name}</h3>
              {store.category && (
                <div class="inline-flex items-center gap-1.5 bg-violet-500/15 border border-violet-500/30 text-violet-400 text-xs font-medium px-2.5 py-1 rounded-full mb-3">
                  <span class="text-violet-400">{store.category}</span>
                </div>
              )}
              {store.description && (
                <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
                  {store.description}
                </p>
              )}
            </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="rounded-3xl overflow-hidden border transition-colors backdrop-blur-sm"
        style="background: linear-gradient(135deg, var(--bg-card) 0%, rgba(139,92,246,0.04) 100%); border-color: var(--border);">
        <div class="grid md:grid-cols-2 gap-0">
          <div class="p-10 flex flex-col justify-center">
            <div class="inline-flex items-center gap-2 bg-emerald-500/15 border border-emerald-500/30 text-emerald-400 text-xs font-semibold px-3 py-1 rounded-full mb-6 w-fit">
              <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></span>
              En producción
            </div>
            <h3 class="text-2xl font-black mb-3" style="color: var(--text-primary);">Quina</h3>
            <p class="text-sm leading-relaxed mb-6" style="color: var(--text-muted);">
              Tienda de indumentaria con catálogo completo, variantes por talla y color, y checkout con Mercado Pago. Panel de administración para gestión de stock y pedidos.
            </p>
            <div class="flex flex-wrap gap-2">
              {['Indumentaria', 'Variantes', 'MP Checkout', 'Admin Panel'].map((tag) => (
                <span class="text-xs px-3 py-1 rounded-full border"
                  style="background-color: var(--bg-card); border-color: var(--border); color: var(--text-muted);">
                  {tag}
                </span>
              ))}
            </div>
          </div>
          <div class="relative flex items-end justify-center p-8 min-h-64"
            style="background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);">
            <img src="/images/hero-light.png" alt="Demo tienda" loading="lazy"
              class="max-h-72 w-auto object-contain drop-shadow-2xl rounded-xl" />
          </div>
        </div>
      </div>
    )}

    <p class="text-center text-sm mt-8" style="color: var(--text-faint);">
      ¿Querés ser el próximo caso de éxito?
      <a href="#contact" class="text-orange-500 hover:text-orange-400 font-semibold ml-1">Hablemos →</a>
    </p>
  </div>
</section>
