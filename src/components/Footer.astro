---
import MapPin from '@lucide/astro/icons/map-pin';
const currentYear = new Date().getFullYear();
const links = [
  { href: '#about', label: 'Sobre mí' },
  { href: '#features', label: 'Características' },
  { href: '#how-it-works', label: 'Cómo funciona' },
  { href: '#clientes', label: 'Clientes' },
  { href: '#contact', label: 'Contacto' },
];
---

<footer class="border-t transition-colors duration-300" style="background-color: var(--bg-secondary); border-color: var(--border);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <div class="grid md:grid-cols-3 gap-8 sm:gap-10 mb-8 sm:mb-10">

      <!-- Brand -->
      <div>
        <img src="/images/logo.png" alt="SmonDev Studio" class="h-11 w-auto rounded-lg mb-4" />
        <p class="text-sm leading-relaxed max-w-xs" style="color: var(--text-muted);">
          Desarrollo de plataformas e-commerce a medida para negocios que quieren crecer sin depender de soluciones genéricas.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: var(--text-faint);">Navegación</h4>
        <ul class="flex flex-col gap-2">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-orange-500 transition-colors" style="color: var(--text-muted);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: var(--text-faint);">Contacto</h4>
        <ul class="flex flex-col gap-2 text-sm" style="color: var(--text-muted);">
          <li class="flex items-center gap-1.5">
            <MapPin class="w-3.5 h-3.5 text-orange-500" />
            Cipolletti, Río Negro, Argentina
          </li>
          <li>
            <a href="#contact" class="hover:text-orange-500 transition-colors">
              Formulario de contacto →
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t flex flex-col sm:flex-row items-center justify-between gap-4 text-sm"
      style="border-color: var(--border); color: var(--text-faint);">
      <span>© {currentYear} SmonDev Studio. Todos los derechos reservados.</span>
      <span>Desarrollo web desde Argentina al mundo</span>
    </div>
  </div>
</footer>
