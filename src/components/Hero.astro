---
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-16 transition-colors duration-300"
  style="background: var(--hero-gradient);">

  <!-- Decorative blobs -->
  <div class="absolute top-20 -right-20 w-[500px] h-[500px] bg-violet-500/10 dark:bg-violet-500/15 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-fuchsia-500/8 dark:bg-fuchsia-500/10 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-cyan-500/5 dark:bg-cyan-500/8 rounded-full blur-[150px] pointer-events-none"></div>
  <div class="absolute bottom-10 right-10 w-72 h-72 bg-orange-500/8 dark:bg-orange-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <div class="grid lg:grid-cols-[0.7fr_1.3fr] gap-6 lg:gap-10 items-center">
      <!-- Text -->
      <div class="order-2 lg:order-1">
        <div class="inline-flex items-center gap-2 bg-orange-500/20 border border-orange-500/30 text-orange-500 text-xs font-semibold px-4 py-1.5 rounded-full mb-6">
          <span class="w-2 h-2 bg-orange-500 rounded-full animate-pulse"></span>
          Disponible para nuevos proyectos
        </div>

        <h1 class="text-3xl sm:text-4xl md:text-5xl font-black leading-tight mb-6 transition-colors duration-300"
          style="color: var(--text-primary);">
          Tu tienda online,<br/>
          <span class="text-orange-500">profesional</span><br/>
          desde el día uno.
        </h1>

        <p class="text-base sm:text-lg leading-relaxed mb-8 max-w-md transition-colors duration-300"
          style="color: var(--text-muted);">
          Desarrollo plataformas de e-commerce completas: catálogo, carrito, pagos con Mercado Pago y panel de administración.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="#contact"
            class="bg-orange-500 hover:bg-orange-400 text-white font-bold px-8 py-3.5 rounded-full transition-all transform hover:scale-105 shadow-lg shadow-orange-500/30"
          >
            Quiero mi tienda →
          </a>
          <a
            href="#features"
            class="font-semibold px-8 py-3.5 rounded-full transition-all border"
            style="border-color: var(--border); color: var(--text-muted);"
          >
            Ver características
          </a>
        </div>

        <!-- Stats -->
        <div class="flex gap-6 sm:gap-8 mt-10">
          <div>
            <div class="text-2xl sm:text-3xl font-black" style="color: var(--text-primary);">Diseño</div>
            <div class="text-xs sm:text-sm mt-1" style="color: var(--text-faint);">Personalizado</div>
          </div>
          <div class="w-px" style="background-color: var(--border);"></div>
          <div>
            <div class="text-2xl sm:text-3xl font-black text-orange-500">Soporte</div>
            <div class="text-xs sm:text-sm mt-1" style="color: var(--text-faint);">Incluido</div>
          </div>
          <div class="w-px" style="background-color: var(--border);"></div>
          <div>
            <div class="text-2xl sm:text-3xl font-black" style="color: var(--text-primary);">Multi</div>
            <div class="text-xs sm:text-sm mt-1" style="color: var(--text-faint);">Escalable</div>
          </div>
        </div>
      </div>

      <!-- Hero image — swaps on theme toggle -->
      <div class="relative flex justify-center items-center order-1 lg:order-2">
        <img
          id="hero-img"
          src="/images/hero-dark.png"
          alt="SmonDev Studio"
          class="relative z-0 w-full h-auto object-contain drop-shadow-2xl rounded-2xl"
          style="max-height: 850px;"
        />
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce"
    style="color: var(--text-faint);">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
