---
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-16 transition-colors duration-300"
  style="background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 50%, var(--bg-primary) 100%);">

  <!-- Decorative blobs -->
  <div class="absolute top-20 right-0 w-96 h-96 bg-orange-500/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-10 w-80 h-80 bg-teal-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-12 items-center">
    <!-- Hero image — swaps on theme toggle -->
    <div class="relative flex justify-center items-end order-1 md:order-2">
      <img
        id="hero-img"
        src="/images/hero-dark.png"
        alt="SmonDev Studio"
        class="relative z-0 max-h-[520px] w-auto object-contain drop-shadow-2xl rounded-2xl"
      />
    </div>

    <!-- Text -->
    <div class="order-2 md:order-1">
      <div class="inline-flex items-center gap-2 bg-orange-500/20 border border-orange-500/30 text-orange-500 text-xs font-semibold px-4 py-1.5 rounded-full mb-6">
        <span class="w-2 h-2 bg-orange-500 rounded-full animate-pulse"></span>
        Disponible para nuevos proyectos
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6 transition-colors duration-300"
        style="color: var(--text-primary);">
        Tu tienda online,<br/>
        <span class="text-orange-500">profesional</span><br/>
        desde el día uno.
      </h1>

      <p class="text-lg leading-relaxed mb-8 max-w-md transition-colors duration-300"
        style="color: var(--text-muted);">
        Desarrollo plataformas de e-commerce completas: catálogo, carrito, pagos con Mercado Pago y panel de administración. Tu negocio, tu sistema.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="#contact"
          class="bg-orange-500 hover:bg-orange-400 text-white font-bold px-8 py-3.5 rounded-full transition-all transform hover:scale-105 shadow-lg shadow-orange-500/30"
        >
          Quiero mi tienda →
        </a>
        <a
          href="#features"
          class="font-semibold px-8 py-3.5 rounded-full transition-all border"
          style="border-color: var(--border); color: var(--text-muted);"
        >
          Ver características
        </a>
      </div>

      <!-- Stats -->
      <div class="flex gap-8 mt-12">
        <div>
          <div class="text-3xl font-black" style="color: var(--text-primary);">A medida</div>
          <div class="text-sm mt-1" style="color: var(--text-faint);">Diseñado para tu negocio</div>
        </div>
        <div class="w-px" style="background-color: var(--border);"></div>
        <div>
          <div class="text-3xl font-black text-orange-500">Soporte</div>
          <div class="text-sm mt-1" style="color: var(--text-faint);">Acompañamiento incluido</div>
        </div>
        <div class="w-px" style="background-color: var(--border);"></div>
        <div>
          <div class="text-3xl font-black" style="color: var(--text-primary);">Multi</div>
          <div class="text-sm mt-1" style="color: var(--text-faint);">Escalable desde el día uno</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce"
    style="color: var(--text-faint);">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
