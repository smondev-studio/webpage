# Supabase (formulario de contacto)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Backend API (listado de tiendas activas)
# Local: http://localhost:3001
# Develop: https://api-develop.smondevstudio.com
# Producción: https://api.smondevstudio.com
PUBLIC_API_URL=https://your-api.com

# Google Analytics (opcional)
# PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console Verification (opcional)
# PUBLIC_GSC_VERIFICATION=your-verification-code
