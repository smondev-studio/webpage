{
  "name": "webpage",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,ts,astro}": [
      "eslint --fix"
    ],
    "*.{js,ts,astro,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@lucide/astro": "^1.24.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^6.4.8",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-astro": "^1.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}